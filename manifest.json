{
  "id": "hunyuan3d2mv",
  "name": "Hunyuan3D-2mv",
  "type": "model",
  "source": "https://github.com/iammojogo-sudo/hunyuan3d_mv_extension_modly",
  "description": "Multi-view image-to-3D mesh generation using Tencent Hunyuan3D-2mv.",
  "version": "1.0.0",
  "author": "Lightning Pixel",
  "vram_gb": 8,
  "tags": [
    "image-to-3d",
    "multi-view",
    "mesh"
  ],
  "nodes": [
    {
      "id": "generate-turbo",
      "name": "Generate Mesh (Turbo)",
      "inputs": [
        "image"
      ],
      "hf_repo": "tencent/Hunyuan3D-2mv",
      "download_check": "hunyuan3d-dit-v2-mv-turbo/model.fp16.safetensors",
      "params_schema": [
        {
          "id": "model_variant",
          "label": "Model Variant",
          "type": "select",
          "default": "hunyuan3d-dit-v2-mv-turbo",
          "options": [
            {
              "value": "hunyuan3d-dit-v2-mv-turbo",
              "label": "Turbo"
            }
          ],
          "tooltip": "Model variant locked for this node."
        },
        {
          "id": "num_inference_steps",
          "label": "Inference Steps",
          "type": "select",
          "default": 30,
          "options": [
            {
              "value": 10,
              "label": "Fast (10)"
            },
            {
              "value": 30,
              "label": "Balanced (30)"
            },
            {
              "value": 50,
              "label": "Quality (50)"
            }
          ],
          "tooltip": "Number of diffusion steps."
        },
        {
          "id": "octree_resolution",
          "label": "Mesh Resolution",
          "type": "select",
          "default": 380,
          "options": [
            {
              "value": 256,
              "label": "Low (256)"
            },
            {
              "value": 380,
              "label": "Medium (380)"
            },
            {
              "value": 512,
              "label": "High (512)"
            }
          ],
          "tooltip": "Octree resolution. Higher values use more VRAM."
        }
      ],
      "output": "mesh",
      "input": "image"
    }
  ],
  "generator_class": "Hunyuan3D2mvGenerator"
}
