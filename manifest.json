{
  "id": "hunyuan3d2mv",
  "name": "Hunyuan3D-2mv",
  "type": "model",
  "source": "https://github.com/iammojogo-sudo/hunyuan3d2mv_extension_modly",
  "description": "Multi-view image-to-3D mesh generation using Tencent Hunyuan3D-2mv. Accepts front, left, back and right view images to reconstruct a detailed untextured mesh. Only the front view is required.",
  "version": "1.0.0",
  "author": "Lightning Pixel",
  "tags": [
    "image-to-3d",
    "multi-view",
    "mesh"
  ],
  "nodes": [
    {
      "id": "generate-turbo",
      "name": "Generate Mesh (Turbo)",
      "inputs": [
        {
          "id": "front_image",
          "type": "image",
          "label": "Front"
        },
        {
          "id": "left_image",
          "type": "image",
          "label": "Left"
        },
        {
          "id": "back_image",
          "type": "image",
          "label": "Back"
        },
        {
          "id": "right_image",
          "type": "image",
          "label": "Right"
        }
      ],
      "output": "mesh",
      "hf_repo": "tencent/Hunyuan3D-2mv",
      "download_check": "hunyuan3d-dit-v2-mv/model.fp16.safetensors",
      "params_schema": [
        {
          "id": "model_variant",
          "label": "Model Variant",
          "type": "select",
          "default": "hunyuan3d-dit-v2-mv-turbo",
          "options": [
            {
              "value": "hunyuan3d-dit-v2-mv-turbo",
              "label": "hunyuan3d-dit-v2-mv-turbo"
            }
          ],
          "tooltip": "Model variant (locked per node)."
        },
        {
          "id": "num_inference_steps",
          "label": "Inference Steps",
          "type": "select",
          "default": 30,
          "options": [
            {
              "value": 10,
              "label": "Fast (10)"
            },
            {
              "value": 30,
              "label": "Balanced (30)"
            },
            {
              "value": 50,
              "label": "Quality (50)"
            }
          ],
          "tooltip": "Number of diffusion steps."
        },
        {
          "id": "octree_resolution",
          "label": "Mesh Resolution",
          "type": "select",
          "default": 380,
          "options": [
            {
              "value": 256,
              "label": "Low (256)"
            },
            {
              "value": 380,
              "label": "Medium (380)"
            },
            {
              "value": 512,
              "label": "High (512)"
            }
          ],
          "tooltip": "Octree resolution. Higher = more detail but more VRAM."
        },
        {
          "id": "seed",
          "label": "Seed",
          "type": "int",
          "default": 42,
          "min": 0,
          "max": 4294967295,
          "tooltip": "Change if result is unsatisfying."
        }
      ],
      "generator_class": "Hunyuan3D2mvTurboGenerator"
    },
    {
