{
  "id": "hunyuan3d2mv",
  "name": "Hunyuan3D-2mv",
  "type": "model",
  "source": "https://github.com/iammojogo-sudo/hunyuan3d_mv_extension_modly",
  "description": "Multi-view image-to-3D mesh generation using Tencent Hunyuan3D-2mv. Accepts front, left, back and right view images to reconstruct a detailed untextured mesh. Only the front view is required.",
  "version": "1.0.0",
  "author": "Lightning Pixel",
  "vram_gb": 8,
  "tags": [
    "image-to-3d",
    "multi-view",
    "mesh"
  ],
  "nodes": [
    {
      "id": "generate-turbo",
      "name": "Generate Mesh (Turbo)",
      "input": "image",
      "inputs": [
        {
          "name": "front",
          "type": "image",
          "required": true
        },
        {
          "name": "left",
          "type": "image",
          "required": false
        },
        {
          "name": "back",
          "type": "image",
          "required": false
